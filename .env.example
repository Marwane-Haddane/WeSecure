# ==============================
# WeSecure Environment Variables
# ==============================
# Copy this file to .env and fill in your real keys:
#   cp .env.example .env

# Flask Secret Key (generate a random one for production)
FLASK_SECRET_KEY=your_flask_secret_key_here

# Groq API Key (get yours at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# n8n Webhook URL (your n8n cloud webhook endpoint)
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/scan-report
